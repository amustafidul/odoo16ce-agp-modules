<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Modern Form View -->
    <template id="modern_form_view" inherit_id="web.form_view">
        <xpath expr="//div[hasclass('o_form_view')]" position="attributes">
            <attribute name="class">o_form_view agp-modern-form</attribute>
        </xpath>
    </template>
    
    <!-- Modern Tree/List View -->
    <template id="modern_tree_view" inherit_id="web.list_view">
        <xpath expr="//div[hasclass('o_list_view')]" position="attributes">
            <attribute name="class">o_list_view agp-modern-tree</attribute>
        </xpath>
    </template>
    
    <!-- Modern Kanban View -->
    <template id="modern_kanban_view" inherit_id="web.kanban_view">
        <xpath expr="//div[hasclass('o_kanban_view')]" position="attributes">
            <attribute name="class">o_kanban_view agp-modern-kanban</attribute>
        </xpath>
    </template>
    
    <!-- Modern Calendar View -->
    <template id="modern_calendar_view" inherit_id="web.calendar_view">
        <xpath expr="//div[hasclass('o_calendar_view')]" position="attributes">
            <attribute name="class">o_calendar_view agp-modern-calendar</attribute>
        </xpath>
    </template>
    
    <!-- Modern Search View -->
    <template id="modern_search_view" inherit_id="web.search_view">
        <xpath expr="//div[hasclass('o_searchview')]" position="attributes">
            <attribute name="class">o_searchview agp-modern-search</attribute>
        </xpath>
    </template>
    
    <!-- Modern Control Panel -->
    <template id="modern_control_panel" inherit_id="web.control_panel">
        <xpath expr="//div[hasclass('o_cp_top')]//div[hasclass('o_cp_command_palette')]" position="attributes">
            <attribute name="class">o_cp_command_palette agp-modern-control-panel</attribute>
        </xpath>
    </template>
    
    <!-- Dashboard-style App Menu (Grid Layout, No Dropdown) -->
    <template id="modern_app_menu_dashboard" inherit_id="web.menu_apps">
        <xpath expr="//div[hasclass('o_menu_apps')]" position="replace">
            <div class="o_menu_apps agp-app-menu-dashboard">
                <div class="agp-apps-grid-container">
                    <t t-foreach="menu_data['children']" t-as="app" t-key="app['id']">
                        <div class="agp-app-item" t-att-data-menu-id="app['id']">
                            <div class="agp-app-icon-wrapper">
                                <i t-att-class="app.get('icon', 'fa fa-th-large')" class="agp-app-icon"/>
                            </div>
                            <span class="agp-app-name" t-esc="app['name']"/>
                        </div>
                    </t>
                </div>
            </div>
        </xpath>
    </template>
    
    <!-- Modern Submenu - Grid Style -->
    <template id="modern_submenu_grid" inherit_id="web.menu_secondary">
        <xpath expr="//div[hasclass('o_menu_submenu')]" position="replace">
            <div class="o_menu_submenu agp-submenu-grid">
                <div class="agp-submenu-header">
                    <span class="agp-submenu-title">Menu</span>
                </div>
                <div class="agp-submenu-items-grid">
                    <t t-foreach="menu_data['children']" t-as="menu" t-key="menu['id']">
                        <t t-call="web.menu_item">
                            <t t-set="menu" t-value="menu"/>
                        </t>
                    </t>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Modern Menu Item -->
    <template id="modern_menu_item" inherit_id="web.menu_item">
        <xpath expr="//a[hasclass('dropdown-item')]" position="replace">
            <a href="#" class="dropdown-item agp-modern-menu-item" t-att-data-menu-id="menu['id']">
                <i t-att-class="menu.get('icon', 'fa fa-circle')" class="agp-menu-item-icon"/>
                <span t-esc="menu['name']" class="agp-menu-item-name"/>
            </a>
        </xpath>
    </template>
</odoo>
