<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Modern Assets Bundle - Extended -->
    <template id="modern_assets_bundle" inherit_id="web.assets_backend">
        <xpath expr="." position="inside">
            <link rel="stylesheet" href="/agp_modern_theme_ib/static/src/css/theme.css"/>
            <script type="module" src="/agp_modern_theme_ib/static/src/js/theme.js"/>
        </xpath>
    </template>
    
    <!-- Modern Web Client Layout -->
    <template id="modern_webclient_layout" name="Modern Web Client">
        <t t-call="web.webclient_layout">
            <t t-set="body_classname" t-value="'agp-modern-theme ' + (body_classname or '')"/>
        </t>
    </template>
</odoo>
